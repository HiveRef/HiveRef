{
    "name": "HiveRef",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/var/www",
    "forwardPorts": [8000, 5174],
    "portsAttributes": {
        "8000": {
            "label": "Laravel (Nginx)",
            "onAutoForward": "notify",
            "visibility": "public"
        },
        "5174": {
            "label": "Vite",
            "onAutoForward": "notify",
            "visibility": "public"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "bradlc.vscode-tailwindcss",
                "dbaeumer.vscode-eslint"
            ]
        }
    }
}
